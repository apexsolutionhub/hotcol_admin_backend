generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "mysql"
}

model user {
  id                          Int       @id @default(autoincrement())
  UserName                    String    @unique
  Password                    String
  /// Display / marketing business name (not necessarily unique)
  HotelName                   String
  /// Tenant id shared by all staff (10-digit TIN or 11–12 digits); matches Item/Order.HotelName — not unique per row
  tinNumber                   String?
  businessType                String?
  modules                     Json?
  Role                        String
  LogoUrl                     String?
  setupFeeETB                 Int?
  quarterlyFeeETB             Int?
  paymentChannel              String?
  paymentTransactionRef       String?
  subscriptionPaidUntil       DateTime?
  subscriptionPaymentApproved Boolean   @default(false)
  setupFeeApproved            Boolean   @default(false)
  paidQuartersCount           Int       @default(0)
  /// Demo / sales property — no payment or subscription enforcement
  isIllustrationTenant        Boolean   @default(false)
  /// Quarters paused until released (legacy clients start on hold)
  billingHold                 Boolean   @default(false)
  /// Set when hold lifts — day 1 for quarter counting
  billingStartedAt            DateTime?
  /// Optional free trial — no quarterly enforcement until this date
  freeTrialEndsAt             DateTime?
  /// Apex notes (discount reason, special terms)
  billingNotes                String?   @db.Text
  createdAt                   DateTime  @default(now())
  /// Apex-only: disable a single staff login without suspending the whole property
  loginDisabled               Boolean   @default(false)
  loginDisabledReason         String?   @db.Text
  loginDisabledAt             DateTime?
  loginDisabledByApexMemberId Int?

  loginDisabledBy apex_team_member? @relation("UserLoginDisabledBy", fields: [loginDisabledByApexMemberId], references: [id], onDelete: SetNull)
  /// Apex locked custom fees — module changes won't auto-overwrite setup/quarterly ETB
  feesManuallySet     Boolean   @default(false)
  /// Last applied row from subscription_pricing_rule (if any)
  pricingRuleId       Int?
  pricingRule         subscription_pricing_rule? @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)

  @@index([tinNumber])
  @@index([loginDisabled])
  @@index([pricingRuleId])
}

/// Module + business-type pricing catalog (setup & quarterly ETB). Sync this model to hotcol-user.
model subscription_pricing_rule {
  id               Int      @id @default(autoincrement())
  businessType     String
  /// Sorted module names joined with | e.g. "Cafe|Inventory"
  modulesKey       String
  modules          Json
  setupFeeETB      Int
  quarterlyFeeETB  Int
  description      String?  @db.Text
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenants user[]

  @@unique([businessType, modulesKey])
  @@index([businessType])
  @@index([isActive])
}

/// Setup & quarterly fee payment proofs awaiting Apex approval.
model tenant_payment_submission {
  id                Int       @id @default(autoincrement())
  tinNumber         String
  /// setup | quarterly | yearly
  paymentKind       String
  amountETB         Int
  paymentChannel    String
  transactionRef    String
  /// pending | approved | rejected
  status            String    @default("pending")
  submittedAt       DateTime  @default(now())
  submittedByUserId Int?
  approvedAt        DateTime?
  approvedByApexMemberId Int?
  rejectedAt        DateTime?
  rejectedByApexMemberId Int?
  rejectionReason   String?   @db.Text
  quarterNumber     Int?

  approvedBy apex_team_member? @relation("PaymentApprovedBy", fields: [approvedByApexMemberId], references: [id], onDelete: SetNull)
  rejectedBy apex_team_member? @relation("PaymentRejectedBy", fields: [rejectedByApexMemberId], references: [id], onDelete: SetNull)

  @@index([tinNumber])
  @@index([status])
  @@index([tinNumber, paymentKind, status])
}

/// Apex internal team — login for the Apex dashboard (separate from tenant `user`).
model apex_team_member {
  id          Int      @id @default(autoincrement())
  UserName    String   @unique
  Password    String
  displayName String?
  /// support | billing | admin
  role        String   @default("support")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feedbackMessages              tenant_feedback_message[]
  auditLogs                     apex_audit_log[]
  tenantsSuspended              tenant_account[]              @relation("TenantSuspendedBy")
  tenantsBanned                 tenant_account[]              @relation("TenantBannedBy")
  usersLoginDisabled            user[]                        @relation("UserLoginDisabledBy")
  paymentsApproved              tenant_payment_submission[]   @relation("PaymentApprovedBy")
  paymentsRejected              tenant_payment_submission[]   @relation("PaymentRejectedBy")
  moduleChangesRequested        tenant_module_change_request[] @relation("ModuleChangeRequestedByApex")
  moduleChangesReviewed         tenant_module_change_request[] @relation("ModuleChangeReviewedBy")
  feedbackThreadsAssigned       tenant_feedback_thread[]      @relation("FeedbackAssignedTo")
  feedbackThreadsClosed         tenant_feedback_thread[]      @relation("FeedbackClosedBy")
}

/// One feedback thread per property (TIN). Cafe Admin / Hotel Manager chat with Apex.
model tenant_feedback_thread {
  id               Int      @id @default(autoincrement())
  tinNumber        String   @unique
  hotelDisplayName String
  businessType     String?
  /// open | closed
  status           String   @default("open")
  assignedApexMemberId Int?
  closedAt         DateTime?
  closedByApexMemberId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages         tenant_feedback_message[]
  assignedTo       apex_team_member? @relation("FeedbackAssignedTo", fields: [assignedApexMemberId], references: [id], onDelete: SetNull)
  closedBy         apex_team_member? @relation("FeedbackClosedBy", fields: [closedByApexMemberId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([updatedAt])
  @@index([assignedApexMemberId])
}

/// Canonical tenant record for the Apex dashboard — one row per business TIN.
model tenant_account {
  id               Int      @id @default(autoincrement())
  tinNumber        String   @unique
  hotelDisplayName String
  businessType     String?
  logoUrl          String?
  /// Subscribed modules (canonical list for the property)
  modules          Json?
  /// active | suspended | banned — subscription/setup states remain on owner `user` row
  accountStatus    String   @default("active")
  suspendedAt      DateTime?
  suspendedReason  String?  @db.Text
  suspendedByApexMemberId Int?
  bannedAt         DateTime?
  bannedReason     String?  @db.Text
  bannedByApexMemberId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  suspendedBy           apex_team_member?            @relation("TenantSuspendedBy", fields: [suspendedByApexMemberId], references: [id], onDelete: SetNull)
  bannedBy              apex_team_member?            @relation("TenantBannedBy", fields: [bannedByApexMemberId], references: [id], onDelete: SetNull)
  moduleChangeRequests  tenant_module_change_request[]

  @@index([accountStatus])
  @@index([updatedAt])
  @@index([hotelDisplayName])
}

/// Tenant or Apex request to change subscribed modules (add/remove, repricing).
model tenant_module_change_request {
  id                      Int      @id @default(autoincrement())
  tinNumber                 String
  requestedModules        Json
  requestNote               String?  @db.Text
  /// pending | approved | rejected | cancelled
  status                    String   @default("pending")
  /// tenant | apex
  requestedBySide           String
  requestedByUserId         Int?
  requestedByApexMemberId   Int?
  reviewedByApexMemberId    Int?
  reviewedAt                DateTime?
  reviewNote                String?  @db.Text
  /// Fee snapshot at approval time (ETB)
  setupFeeETB               Int?
  quarterlyFeeETB           Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenantAccount   tenant_account    @relation(fields: [tinNumber], references: [tinNumber], onDelete: Cascade)
  requestedByApex apex_team_member? @relation("ModuleChangeRequestedByApex", fields: [requestedByApexMemberId], references: [id], onDelete: SetNull)
  reviewedByApex  apex_team_member? @relation("ModuleChangeReviewedBy", fields: [reviewedByApexMemberId], references: [id], onDelete: SetNull)

  @@index([tinNumber])
  @@index([status])
  @@index([createdAt])
}

/// Immutable log of sensitive Apex dashboard actions.
model apex_audit_log {
  id              Int      @id @default(autoincrement())
  apexMemberId    Int?
  /// Short action code, e.g. approve_setup, suspend_tenant, update_modules
  action          String
  targetTinNumber String?
  targetUserId    Int?
  payload         Json?
  reason          String?  @db.Text
  createdAt       DateTime @default(now())

  apexMember apex_team_member? @relation(fields: [apexMemberId], references: [id], onDelete: SetNull)

  @@index([targetTinNumber])
  @@index([targetUserId])
  @@index([apexMemberId])
  @@index([action])
  @@index([createdAt])
}

model tenant_feedback_message {
  id              Int      @id @default(autoincrement())
  threadId        Int
  /// tenant | apex
  senderSide      String
  tenantUserId    Int?
  tenantUserName  String?
  tenantRole      String?
  apexMemberId    Int?
  apexDisplayName String?
  body            String   @db.Text
  imageUrl        String?  @db.VarChar(2048)
  readByTenant    Boolean  @default(false)
  readByApex      Boolean  @default(false)
  createdAt       DateTime @default(now())

  thread     tenant_feedback_thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  apexMember apex_team_member?      @relation(fields: [apexMemberId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([createdAt])
  @@index([senderSide, readByTenant])
  @@index([senderSide, readByApex])
}

model Item {
  id                  Int      @id @default(autoincrement())
  name                String
  price               Float
  category            String
  type                String
  HotelName           String
  imageUrl            String
  /// When true, kitchen/bar prep summary shows aggregated quantity for this item.
  showStationPrepQty  Boolean  @default(true)
  createdAt           DateTime @default(now())
}

model cashouts {
  id             Int      @id @default(autoincrement())
  items          Json
  prices         Json
  measuredBy     Json
  requiredAmount Json
  totalCalc      Float
  HotelName      String
  createdAt      DateTime @default(now())
}

model Order {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String
  tableNo     Int
  category    String
  type        String
  orderAmount Int
  HotelName   String
  price       Float
  waiterName  String
  status      String?
  payment     String?
  withBank    Boolean?
  credit      Boolean?
  credittorName String?
  creditAmount  Float?
  /// Actual bank transfer received (may exceed line total when tip included).
  bankTransferAmount   Float?
  /// Cash withdrawn from till for waiter tip on bank payments.
  bankTipCashDeduction Float?
  /// Copied from table.orderCaption at order time (e.g. Takeaway, Delivery).
  serviceCaption String?
  /// Role/station that cancelled the line (Cashier, Chef/Kitchen, Barista, etc.).
  cancelledBy   String?
  /// Set when cashier edits table, waiter, or quantity — kitchen/bar highlight.
  orderRevisedAt     DateTime? @map("quantityRevisedAt")
  orderRevisionCount Int       @default(0)
  createdAt   DateTime @default(now())

  @@index([HotelName])
  @@index([HotelName, status])
}

model waiter {
  id           Int      @id @default(autoincrement())
  name         String
  HotelName    String
  sex          String
  age          Int
  experience   Int
  phoneNumber  String
  price        Json     @default("[]")
  tablesServed Json     @default("[]")
  payment      Json     @default("[]")
  incomeAt     Json     @default("[]")
  createdAt    DateTime @default(now())
}

model table {
  id           Int      @id @default(autoincrement())
  tableNo      Int
  capacity     Int
  /// Optional label applied to orders from this table (e.g. Takeaway, Delivery).
  orderCaption String?
  price        Json     @default("[]")
  payment      Json     @default("[]")
  incomeAt     Json     @default("[]")
  HotelName    String
  createdAt    DateTime @default(now())
}

model creditLevel {
  id           Int      @id @default(autoincrement())
  level        String
  requiredAmount Float
  timeInterval  Int
  timeFrame       String
  HotelName    String
}

model pityCash {
  id        Int      @id @default(autoincrement())
  amount    Float
  startDate DateTime
  endDate   DateTime
  HotelName String
}

model CreditRegistration {
  id                 Int       @id @default(autoincrement())
  imageUrl           String
  name               String
  sex                String
  creditLevel        String
  phoneNumber        String
  amount             Float
  timeInterval       Int
  timeFrame          String
  paidAmount         Float
  registrationDate   DateTime  @default(now())
  HotelName          String
  registrantType     String    @default("STAFF")
  approvalStatus     String    @default("AUTHORIZED")
  companyTinNumber   String    @default("")
  affiliatedCompany  String    @default("")
  rejectionReason    String?
  adminActorName     String?
  adminAuthorizedAt  DateTime?
}

/// Per-hotel voucher sequence counters (purchase request, item registration, stock movement).
model HotelVoucherCounter {
  id          Int    @id @default(autoincrement())
  HotelName   String
  voucherType String
  lastNumber  Int    @default(0)

  @@unique([HotelName, voucherType])
  @@index([HotelName])
}

model ItemRegistration {
  id                Int      @id @default(autoincrement())
  name              String
  imageUrl          String
  category          String
  amount            Float
  measuredBy        String
  unitPrice         Float
  registrationDate  DateTime 
  expireDate        DateTime
  supplierName      String
  supplierPhone     String
  Address           String
  /// When true, unit price / line totals were agreed including VAT.
  purchaseWithVat   Boolean  @default(false)
  supplierTinNumber String   @default("")
  paidAmount        Float
  HotelName         String
  /// Store staff who registered this line (hotel draft / review workflow).
  statusBy          String?
  /// Per-hotel sequential voucher (display padded to 4+ digits).
  voucherNumber     Int?
  /// Linked purchase request voucher when goods are received against a PR.
  purchaseRequestId Int?
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | AUTHORIZED | REJECTED_* | VOID
  approvalStatus    String   @default("PENDING_CC")
  ccProfileId       Int?
  ccActorName       String?
  ccCheckedAt       DateTime?
  financeActorName  String?
  financeApprovedAt DateTime?
  managerActorName  String?
  managerAuthorizedAt DateTime?
  rejectionReason   String?
  /// Unit price revision after initial authorization (same 3-tier flow as purchase requests).
  pendingUnitPrice    Float?
  unitPriceChangeStatus String?
  /// STORE | KITCHEN | BAR — receiving department for goods.
  receivedByDepartment  String?
  receivedByLeaderName  String?
  financeDeptLeaderName String?
  gmDeptLeaderName      String?

  @@index([HotelName])
  @@index([approvalStatus])
}

model ItemStatus {
  id           Int      @id @default(autoincrement())
  name         String
  imageUrl     String
  category     String
  amount       Float
  measuredBy   String
  unitPrice    Float
  actionDate   DateTime
  supplierName String
  supplierPhone String
  Address       String
  purchaseWithVat   Boolean  @default(false)
  supplierTinNumber String   @default("")
  paidAmount     Float
  status         String
  statusBy       String
  HotelName      String
  /// Stock movement voucher when created from an approved hotel stock-out request.
  voucherNumber     Int?
  stockOutRequestId Int?

  @@index([HotelName])
  @@index([stockOutRequestId])
}

/// One named leader per department per hotel (manager-maintained).
model DepartmentLeader {
  id         Int      @id @default(autoincrement())
  HotelName  String
  department String
  leaderName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([HotelName, department])
  @@index([HotelName])
}

/// Named individuals sharing the Cost Control login — selected when approving.
model CostControllerProfile {
  id          Int      @id @default(autoincrement())
  displayName String
  HotelName   String
  createdAt   DateTime @default(now())

  @@index([HotelName])
}

/// Store requests to buy items not currently in stock. CC check → Finance approve → Manager authorize.
model PurchaseRequest {
  id                  Int       @id @default(autoincrement())
  HotelName           String
  itemName            String
  quantity            Float
  measuredBy          String
  notes               String    @default("")
  estimatedUnitPrice  Float     @default(0)
  supplierName        String    @default("")
  supplierPhone       String    @default("")
  category            String    @default("Others")
  purchaseWithVat     Boolean   @default(true)
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | AUTHORIZED | REJECTED_* | legacy APPROVED_FINANCE
  status              String
  storeUserName       String
  voucherNumber       Int?
  ccProfileId         Int?
  ccActorName         String?
  ccApprovedAt        DateTime?
  financeActorName    String?
  financeApprovedAt   DateTime?
  managerActorName    String?
  managerAuthorizedAt DateTime?
  rejectionReason     String?
  /// Unit price revision after initial approval (same 3-tier flow).
  pendingUnitPrice    Float?
  unitPriceChangeStatus String?
  requestedByDepartment String?
  requestedByLeaderName String?
  preparedByLeaderName  String?
  financeDeptLeaderName String?
  gmDeptLeaderName      String?
  entranceDate        DateTime  @default(now())
  createdAt           DateTime  @default(now())

  @@index([HotelName])
  @@index([status])
}

/// Hotel store movements: CC check → Finance approve → Manager authorize → inventory update.
model StockOutRequest {
  id                   Int      @id @default(autoincrement())
  HotelName            String
  itemRegistrationId   Int
  /// Item name when this request was created (kept if the stock row is removed later).
  itemNameSnapshot     String   @default("")
  /// STOCK_OUT | WASTAGE | RETURN_SUPPLIER
  movementType         String
  amount               Float
  stakeHolderOrReason  String
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | APPROVED | REJECTED | legacy PENDING
  status               String
  voucherNumber        Int?
  requestedByUserName  String
  ccProfileId          Int?
  ccActorName          String?
  ccCheckedAt          DateTime?
  financeActorName     String?
  financeApprovedAt    DateTime?
  managerActorName     String?
  managerAuthorizedAt  DateTime?
  decidedAt            DateTime?
  rejectionReason      String?
  requestedByDepartment String?
  requestedByLeaderName String?
  preparedByLeaderName  String?
  financeDeptLeaderName String?
  gmDeptLeaderName      String?
  createdAt            DateTime @default(now())

  @@index([HotelName])
  @@index([status])
}

/// Daily chef / bar count rows (opening pulse, documented stock-out, closing on-hand).
/// Implied movement for a day is derived when the next day’s opening is recorded: opening + stockOut − nextOpening.
model KitchenBarBeginning {
  id          Int      @id @default(autoincrement())
  HotelName   String
  /// CHEF | BAR
  station     String
  itemName    String
  /// Opening pulse — count at the start of calendarDate (same unit as inventory).
  amount      Float
  measuredBy  String
  /// YYYY-MM — kept in sync with calendarDate for reporting and sync jobs.
  monthPeriod String
  /// YYYY-MM-DD — one logical row per station + item + day.
  calendarDate   String   @default("")
  /// Units issued / logged out that day (usage trail).
  stockOutDay    Float    @default(0)
  /// Units issued from station stock to management in that day.
  managementTakenDay Float @default(0)
  /// Physical on-hand at end of day (lights-out snapshot).
  closingOnHand  Float    @default(0)
  notes       String   @default("")
  createdAt   DateTime @default(now())

  @@index([HotelName])
  @@index([monthPeriod])
  @@index([calendarDate])
  @@index([HotelName, station, itemName, calendarDate])
}

/// Rolled-up figures after “Sync monthly inventory” from daily rows for a month.
model KitchenBarMonthlySnapshot {
  id                   Int      @id @default(autoincrement())
  HotelName            String
  station              String
  itemName             String
  monthPeriod          String
  /// Sum of implied daily movement units for that month (excludes the anchor day).
  totalImpliedSales    Float    @default(0)
  /// closingOnHand from the last calendar day present in that month for this key.
  lastDayClosingOnHand Float    @default(0)
  syncedAt             DateTime @default(now())

  @@unique([HotelName, station, itemName, monthPeriod])
  @@index([HotelName])
  @@index([monthPeriod])
}

/// Manager-defined tier (ceiling + period) for hotel corporate credit — cashier picks one per company.
model HotelCorporateCreditTier {
  id            Int      @id @default(autoincrement())
  HotelName     String
  name          String
  creditCeiling Float
  timeInterval  Int
  timeFrame     String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  companies HotelCreditCompany[]

  @@index([HotelName])
}

/// Corporate credit account registered by hotel cashier (B2B meals).
model HotelCreditCompany {
  id              Int      @id @default(autoincrement())
  HotelName       String
  companyName     String
  companyTinNumber String  @default("")
  contactName     String   @default("")
  phoneNumber     String   @default("")
  email           String   @default("")
  /// NOW | AFTER_SERVICE — pay before or after receiving meals.
  payTiming       String   @default("AFTER_SERVICE")
  /// PENDING_MANAGER | AUTHORIZED | REJECTED
  approvalStatus  String   @default("PENDING_MANAGER")
  managerActorName String?
  managerAuthorizedAt DateTime?
  rejectionReason String?
  /// Snapshot label from the tier at registration time.
  creditLevel     String
  /// Money ceiling for the deal window (same spirit as cafe credit amount).
  creditLimit     Float
  timeInterval    Int
  timeFrame       String
  hotelCorporateCreditTierId Int?
  tier            HotelCorporateCreditTier? @relation(fields: [hotelCorporateCreditTierId], references: [id], onDelete: SetNull)
  /// JSON: [{ "name": "...", "itemId"?: number }]
  allowedMenuJson String   @db.Text
  dealNotes       String   @default("")
  imageUrl        String   @default("")
  /// Presale / amount paid upfront when payTiming is NOW.
  paidAmount      Float    @default(0)
  createdAt       DateTime @default(now())

  parties      HotelCreditParty[]
  consumptions HotelCreditConsumption[]

  @@index([HotelName])
  @@index([hotelCorporateCreditTierId])
  @@index([approvalStatus])
}

/// Staff or guest registered under a company account.
model HotelCreditParty {
  id          Int      @id @default(autoincrement())
  HotelName   String
  companyId   Int
  displayName String
  phoneNumber String   @default("")
  sex         String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())

  company      HotelCreditCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consumptions HotelCreditConsumption[]

  @@index([HotelName])
  @@index([companyId])
}

/// One consumption event (timestamped for reporting); not visible to hotel store role in UI.
model HotelCreditConsumption {
  id          Int      @id @default(autoincrement())
  HotelName   String
  companyId   Int
  partyId     Int
  /// JSON array: [{ "name": "", "qty": 1, "unitPrice": 0 }]
  linesJson   String   @db.Text
  totalAmount Float
  occurredAt  DateTime @default(now())
  recordedBy  String

  company HotelCreditCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  party   HotelCreditParty   @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([HotelName])
  @@index([companyId])
  @@index([occurredAt])
}
